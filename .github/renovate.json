{
  "extends": [
    "config:recommended",
    "schedule:weekly"
  ],
  "rangeStrategy": "update-lockfile",
  "packageRules": [
    {
      "matchFileNames": [
        "+(composer.json)"
      ],
      "enabled": true,
      "groupName": "root-composer"
    },
    {
      "matchFileNames": [
        ".github/**"
      ],
      "enabled": true,
      "groupName": "github-actions"
    }
  ]
}
